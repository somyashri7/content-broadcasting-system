{
  "info": {
    "name": "Content Broadcasting System API",
    "description": "Complete API collection for testing the Content Broadcasting System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Teacher",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Teacher\",\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"teacher\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Register Principal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Principal\",\n  \"email\": \"principal@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"principal\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login Teacher",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Login Principal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Content",
      "item": [
        {
          "name": "Upload Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Mathematics Basics",
                  "type": "text"
                },
                {
                  "key": "subject",
                  "value": "mathematics",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Introduction to algebra and equations",
                  "type": "text"
                },
                {
                  "key": "start_time",
                  "value": "2026-04-28T09:00:00Z",
                  "type": "text"
                },
                {
                  "key": "end_time",
                  "value": "2026-04-28T10:00:00Z",
                  "type": "text"
                },
                {
                  "key": "rotation_duration",
                  "value": "5",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/content/upload",
              "host": ["{{base_url}}"],
              "path": ["content", "upload"]
            }
          },
          "response": []
        },
        {
          "name": "Get My Content",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/content/my?status=pending&subject=mathematics",
              "host": ["{{base_url}}"],
              "path": ["content", "my"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                },
                {
                  "key": "subject",
                  "value": "mathematics"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Content By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/content/{{content_id}}",
              "host": ["{{base_url}}"],
              "path": ["content", "{{content_id}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Approval",
      "item": [
        {
          "name": "Get All Content",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/approval/all?status=pending&subject=mathematics",
              "host": ["{{base_url}}"],
              "path": ["approval", "all"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                },
                {
                  "key": "subject",
                  "value": "mathematics"
                },
                {
                  "key": "teacher_id",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Pending Content",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/approval/pending",
              "host": ["{{base_url}}"],
              "path": ["approval", "pending"]
            }
          },
          "response": []
        },
        {
          "name": "Approve Content",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/approval/{{content_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["approval", "{{content_id}}", "approve"]
            }
          },
          "response": []
        },
        {
          "name": "Reject Content",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rejection_reason\": \"Content does not meet quality standards\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/approval/{{content_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["approval", "{{content_id}}", "reject"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Broadcasting",
      "item": [
        {
          "name": "Get Live Content (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/content/live/{{teacher_id}}?subject=mathematics",
              "host": ["{{base_url}}"],
              "path": ["content", "live", "{{teacher_id}}"],
              "query": [
                {
                  "key": "subject",
                  "value": "mathematics"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string",
      "description": "Switch between: http://localhost:5000 (local) or https://content-broadcasting-system-production.up.railway.app (production)"
    },
    {
      "key": "local_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "production_url",
      "value": "https://content-broadcasting-system-production.up.railway.app",
      "type": "string"
    },
    {
      "key": "teacher_token",
      "value": "",
      "type": "string",
      "description": "JWT token from teacher login - copy from response after login"
    },
    {
      "key": "principal_token",
      "value": "",
      "type": "string",
      "description": "JWT token from principal login - copy from response after login"
    },
    {
      "key": "content_id",
      "value": "",
      "type": "string",
      "description": "Content ID from upload response - use for approve/reject/get endpoints"
    },
    {
      "key": "teacher_id",
      "value": "",
      "type": "string",
      "description": "Teacher user ID from registration response - use for live broadcast endpoint"
    }
  ]
}
